{
  "name": "paintball-community-app",
  "version": "0.1.0",
  "private": true,
  "description": "A comprehensive social platform and marketplace for the paintball industry",
  "workspaces": [
    "mobile",
    "backend",
    "shared"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:db": "node scripts/dev-db.mjs",
    "mobile": "cd mobile && npm start",
    "mobile:ios": "cd mobile && npm run ios",
    "mobile:android": "cd mobile && npm run android",
    "backend": "cd backend && npm run start:dev",
    "backend:build": "cd backend && npm run build",
    "backend:prod": "cd backend && npm run start:prod",
    "install:all": "npm install && cd mobile && npm install && cd ../backend && npm install && cd ../shared && npm install",
    "clean": "rm -rf node_modules mobile/node_modules backend/node_modules shared/node_modules",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspaces",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "db:migrate": "npm run migration:run --workspace=@pbg/backend",
    "db:seed": "npm run seed --workspace=@pbg/backend"
    ,"test:launch": "node scripts/launch-smoke.mjs"
  },
  "devDependencies": {
    "@vercel/node": "^5.1.16",
    "typescript": "5.3.3",
    "prettier": "^3.1.0",
    "husky": "^8.0.3",
    "embedded-postgres": "18.4.0-beta.17",
    "lint-staged": "^15.1.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ArandMedia/PBG.git"
  },
  "keywords": [
    "paintball",
    "social",
    "marketplace",
    "tournament",
    "mobile",
    "react-native"
  ],
  "author": "PBG Team",
  "license": "UNLICENSED"
}
